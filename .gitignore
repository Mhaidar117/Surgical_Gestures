checkpoints/

# Reports directory: ignore all contents EXCEPT the README hero figure.
# The chain of !rules is required because gitignore cannot re-include a file
# whose parent directory is excluded — we have to un-ignore each level down.
reports/*
!reports/skill_manifold_fls/
reports/skill_manifold_fls/*
!reports/skill_manifold_fls/ushape/
reports/skill_manifold_fls/ushape/*
!reports/skill_manifold_fls/ushape/individual_u_positions.png

